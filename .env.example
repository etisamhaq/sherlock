# --- LLM (bring your own key) ---
# Sherlock calls Claude for root-cause synthesis. Get a key at https://console.anthropic.com
ANTHROPIC_API_KEY=

# Model used for root-cause synthesis (reasoning-heavy). Default: claude-opus-4-8
SHERLOCK_LLM_MODEL=claude-opus-4-8

# Set to "fake" to run fully offline with the deterministic heuristic engine (no API key needed).
# Useful for demos, CI, and air-gapped trials. Default: anthropic
SHERLOCK_LLM_PROVIDER=anthropic

# --- Slack delivery (optional) ---
# Incoming webhook URL. If unset, Sherlock prints results to stdout instead.
SHERLOCK_SLACK_WEBHOOK_URL=

# --- Prometheus (optional) ---
# Base URL of your Prometheus HTTP API, e.g. http://prometheus.monitoring:9090
SHERLOCK_PROMETHEUS_URL=

# --- Git / "what changed" (optional) ---
# A GitHub or GitLab token + repo so Sherlock can correlate incidents to recent deploys.
SHERLOCK_GIT_PROVIDER=          # github | gitlab | (empty to disable)
SHERLOCK_GIT_TOKEN=
SHERLOCK_GIT_REPO=              # e.g. owner/repo (GitHub) or group/project (GitLab)

# --- Guardrails ---
# Hard ceiling on output tokens spent per investigation (protects cost). Default: 20000
SHERLOCK_TOKEN_BUDGET=20000
# Wall-clock budget per investigation, in seconds. Default: 180
SHERLOCK_TIME_BUDGET_SECONDS=180

# --- Kubernetes ---
# Sherlock uses in-cluster config when running as a pod, or your kubeconfig locally.
# Read-only RBAC is sufficient for investigation.
